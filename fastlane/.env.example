# Copy to fastlane/.env (gitignored) and fill in the real value.
# Password for build/neonrunner.keychain-db, used by the `ship` lane's
# unlock_keychain step so codesign can reach the distribution private key
# over SSH (otherwise: errSecInternalComponent mid-archive).
# Leave blank if the fastlane-created keychain has an empty password.
NEON_KEYCHAIN_PW=
