; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Neon Splice"
config/description="Neon Splice — a fast, glowing geometric runner for iOS & Android."
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"
; Boot is the entry point of the 6-screen flow (docs/design/SCREENS.md): it loads, then
; SceneManager (#60) drives BOOT -> TITLE -> RUN -> RESULTS + the TITLE branches. The Run
; slice (analog steer + always-on fire #9/#10/#52) is now reached via TITLE > PLAY. The
; POC glow stress scene (#6) stays in-tree at res://assets/poc/glow_stress.tscn for perf re-tests.
run/main_scene="res://assets/ui/boot.tscn"

[autoload]

; Global signal bus — registered first so all other singletons/scenes can rely
; on it existing. (The IMPLEMENTATION_PLAN ObjectPool autoload was dropped — issue
; #5 closed as superseded: the fleet/enemies are MultiMesh-batched, not node-pooled.)
Events="*res://autoload/events.gd"
; Colour design tokens (HDR + HUD). No deps (pure consts) — early so every entity's
; visual code can reference Palette.* at runtime.
Palette="*res://autoload/palette.gd"
; Typography design tokens (the 4 bundled fonts + a default Theme). No deps; loads
; defensively so a pre-import headless run just falls back to the engine font.
Fonts="*res://autoload/fonts.gd"
; Persisted player options (haptics + AMOLED). Depends on Events (emits on change).
Settings="*res://autoload/settings.gd"
; Ship loadout (#67 Garage): hull/trail/engine selection, persisted. Depends on Events.
Loadout="*res://autoload/loadout.gd"
; Splice Lab (#68): power-up modifier inventory + fusion, persisted. Depends on Events.
SpliceLab="*res://autoload/splice_lab.gd"
; Run state + economy (projectile_count/score/finish). Depends on Events.
GameState="*res://autoload/game_state.gd"
; Tactile feedback tiers. Depends on Events (listens) + Settings (master switch).
Haptics="*res://autoload/haptics.gd"
; Procedural audio (#24/#25/#61): synthesises all SFX + music into AudioStreamWAV at startup, owns
; the Music/SFX buses, and self-wires event->sound. Depends on Events + Settings (sfx/music switches).
AudioManager="*res://autoload/audio_manager.gd"
; Screen-flow driver + app state machine (#60/#8). Listens to Events run terminals; reads
; GameState for Results. Registered last so every singleton it leans on already exists.
SceneManager="*res://autoload/scene_manager.gd"

[display]

; Portrait, base design resolution 1080x1920 (9:16). Stretch scales the 2D
; canvas to fit any device aspect; "expand" reveals extra space on taller/wider
; phones rather than letterboxing — design UI against anchors + the safe area.
window/size/viewport_width=1080
window/size/viewport_height=1920
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

; Let mouse drive touch events so the game is testable on desktop.
pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
; HDR 2D buffer so Color RGB values > 1.0 feed the WorldEnvironment glow/bloom.
viewport/hdr_2d=true
; ASTC covers both iOS (Metal) and modern Android (Vulkan) mobile GPUs, so all
; future texture imports land in a mobile-friendly compressed format.
textures/vram_compression/import_etc2_astc=true
; 2x MSAA cleans up the neon Line2D edges cheaply on tile-based mobile GPUs.
; Tunable in Phase 7 (Optimization) if it costs frames on mid-range devices.
anti_aliasing/quality/msaa_2d=1
